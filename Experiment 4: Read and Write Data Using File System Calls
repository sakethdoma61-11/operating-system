#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int fd;
    char data[100];

    fd = open("sample.txt", O_CREAT | O_RDWR, 0644);

    write(fd, "Hello OS Lab", 12);

    lseek(fd, 0, SEEK_SET);

    read(fd, data, 12);
    data[12] = '\0';

    printf("Data: %s\n", data);

    close(fd);

    return 0;
}
