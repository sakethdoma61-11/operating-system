#include <stdio.h>

#define MAX 5

int q[MAX], front = -1, rear = -1;

void enqueue(int p)
{
    if (rear == MAX - 1)
        printf("Queue Full\n");
    else
    {
        if (front == -1)
            front = 0;
        q[++rear] = p;
    }
}

void dequeue()
{
    if (front == -1 || front > rear)
        printf("Queue Empty\n");
    else
        printf("Executed Process: %d\n", q[front++]);
}

int main()
{
    enqueue(1);
    enqueue(2);
    enqueue(3);

    dequeue();
    dequeue();

    return 0;
}
